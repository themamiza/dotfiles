#!/bin/bash

[ -z "$1" ] && { cat /sys/bus/cpu/devices/cpu0/cpufreq/scaling_max_freq; exit 0; }

re='^[0-9]+$'
min=$(cat /sys/bus/cpu/devices/cpu0/cpufreq/cpuinfo_min_freq)
max=$(cat /sys/bus/cpu/devices/cpu0/cpufreq/cpuinfo_max_freq)
preserve=$((min + 1000000)) # 1GHz above the minimum
half=$(((min + max) / 2))   # Half the allowed range

isRoot()
{
	[ "$EUID" == 0 ] || { printf "Only root can change cpu frequency.\n"; exit 1; }
}

usage()
{
	printf "Usage: cpufreq [-s frequency] [-m mode]\n"
}

fset()
{
	[ -n "$1" ] || { printf "ERROR: No frequency provided\n"; exit 1; }
	[[ $1 =~ $re ]] || { printf "ERROR: Invalid number\n"; exit 1; }
	if [ "$1" -gt "$max" ] || [ "$1" -lt "$min" ]; then
		printf "ERROR: Invalid frequency\n"; exit 1
	fi

	printf "%s\n" "$1" | tee /sys/bus/cpu/devices/cpu*/cpufreq/scaling_max_freq >/dev/null
}

fmodeset()
{
	[ -n "$1" ] || { printf "ERROR: No frequency mode provided\n"; exit 1; }
	case "$1" in
		"performance"|"normal"|"max") fset "$max";;
		"half") fset "$half";;
		"preserve") fset "$preserve";;
		"potato"|"min") fset "$min";;
		*) printf "ERROR: Invalid frequency mode '%s'\n" "$1"; exit 1;;
	esac
}

while [[ $# -gt 0 ]]; do
	case "$1" in
		"-h") usage; exit 0;;
		"-s") 
			isRoot
			fset "$2"
			shift 2
			;;
		"-m")
			isRoot
			fmodeset "$2"
			shift 2
			;;
		*) printf "ERROR: Invalid option: %s\n" "$1"; usage; exit 1;;
	esac
done
