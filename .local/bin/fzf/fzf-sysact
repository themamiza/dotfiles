#!/bin/sh

case "$WM" in
	"dwm")
		case "$(printf "рџ”’ lockdown\nрџљЄ leave dwm\nрџЄџ restart dwm\nрџ’¤ suspend\nрџђ» hibernate\nрџ”ѓ reboot\nрџ’» shutdown\nрџ“є display off\nвЏ° uptime" | dmenu -i -p "action: ")" in
			"рџ”’ lockdown") notify-send "locking down" && sleep 2 && slock;;
			"рџљЄ leave dwm") kill -term "$(pidof dwm)";;
			"рџЄџ restart dwm") kill -hup "$(pidof dwm)";;
			"рџ’¤ suspend") slock systemctl suspend -i;;
			"рџђ» hibernate") slock systemctl hibernate -i;;
			"рџ”ѓ reboot") notify-send "rebooting the system" && setsid -f bash -c "sleep 2; shutdown -r now";;
			"рџ’» shutdown") notify-send "going down" && setsid -f bash -c "sleep 2; shutdown -h now";;
			"рџ“є display off") xset dpms force off;;
			"вЏ° uptime") notify-send "$(uptime -p)" ;;
			*) exit 1;;
		esac
		;;
	"hyprland")
		case "$(printf "рџ”’ lockdown\nрџљЄ leave hyprland\nрџЄџ restart hyprland\nрџ’¤ suspend\nрџђ» hibernate\nрџ”ѓ reboot\nрџ’» shutdown\nрџ“є display off\nвЏ° uptime" | fzf)" in
			"рџ”’ lockdown") notify-send "locking down" && setsid -f bash -c "sleep 2; hyprlock --grace 5";;
			"рџљЄ leave hyprland") hyprctl dispatch "hl.dsp.exit()";;
			"рџЄџ restart hyprland") hyprctl reload;;
			"рџ’¤ suspend") setsid -f hyprlock; systemctl suspend -i;;
			"рџђ» hibernate") setsid -f hyprlock; systemctl hibernate -i;;
			"рџ”ѓ reboot") notify-send "rebooting the system" && setsid -f bash -c "sleep 2; shutdown -r now";;
			"рџ’» shutdown") notify-send "going down" && setsid -f bash -c "sleep 2; shutdown -h now";;
			"рџ“є display off") hyprctl dispatch dpms off;;
			"вЏ° uptime") notify-send "$(uptime -p)" ;;
			*) exit 1;;
		esac
		;;
esac
