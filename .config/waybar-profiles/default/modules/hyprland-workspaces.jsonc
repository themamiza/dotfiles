{
    "hyprland/workspaces": {
        "active-only": false,
        "workspace-taskbar": true,

        "enable-bar-scroll": true,

        "format": "{icon}",
        "format-icons": {
            "default": "",
            "active": ""
        },

        "persistent-workspaces": {
            "*": 9
        },

        "tooltip": false
    }
}
